<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Tema base dell'app demo. Eredita dal framework (nessuna dipendenza da
         com.google.android.material): la UI vera e' tutta Compose Material3.
         Status/navigation bar TRASPARENTI per il vero edge-to-edge: la mappa
         disegna sotto la barra notifiche e quella di sistema. -->
    <style name="Theme.EnaideDemo" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>
    </style>
</resources>
